# Google Workspace CLI (gws) — maintainer toolkit
# Copy to .env (gitignored). See docs/developer/approach/google-workspace-cli.md

# Path to OAuth credentials JSON (user export or service account key)
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=

# GCP project ID override (matches config/google.json projectId)
GOOGLE_WORKSPACE_PROJECT_ID=

# Pre-obtained access token (highest priority; short-lived)
GOOGLE_WORKSPACE_CLI_TOKEN=

# Optional: service account key path (legacy alias — prefer CREDENTIALS_FILE)
# GOOGLE_SERVICE_ACCOUNT_KEY=
